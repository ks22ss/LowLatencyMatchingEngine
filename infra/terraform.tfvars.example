# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored (contains your IP / key name).

region   = "ap-southeast-1"
key_name = "my-keypair"           # An existing EC2 key pair name in this region
my_ip    = "YOUR_PUBLIC_IP/32"    # Your IP for SSH + Grafana access (curl ifconfig.me)

# repo_url    = "https://github.com/ks22ss/LowLatencyMatchingEngine.git"
# repo_branch = "main"

# Instance types
# engine_instance_type     = "c5.xlarge"
# loadgen_instance_type    = "c5.large"
# monitoring_instance_type = "t3.medium"

# Load generator settings
# loadgen_count      = 10
# loadgen_duration   = "5m"
# loadgen_rate       = 10000   # msg/s per loadgen instance
# loadgen_conns      = 4       # TCP connections per loadgen
# loadgen_cancel_pct = 10      # percent cancel messages
# loadgen_batch      = 128     # frames per TCP write (64–256 typical)
